rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/districts/$(request.auth.uid)/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && getUserData().role in roles;
    }
    
    function isInDistrict(districtId) {
      return isAuthenticated() && getUserData().districtId == districtId;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }
    
    function isDriver() {
      return hasRole('driver');
    }
    
    function isGuardian() {
      return hasRole('guardian');
    }
    
    function isStudent() {
      return hasRole('student');
    }
    
    // Districts collection
    match /districts/{districtId} {
      allow read: if isAuthenticated() && isInDistrict(districtId);
      allow write: if false; // Only via admin console
      
      // Users subcollection
      match /users/{userId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == userId ||
          isAdmin()
        );
        allow create: if isAdmin();
        allow update: if isAuthenticated() && (
          request.auth.uid == userId ||
          isAdmin()
        );
        allow delete: if isAdmin();
      }
      
      // Students subcollection
      match /students/{studentId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          isDriver() ||
          (isGuardian() && request.auth.uid in resource.data.guardianIds) ||
          (isStudent() && request.auth.uid == resource.data.userId)
        );
        allow create, update, delete: if isAdmin();
      }
      
      // Routes subcollection
      match /routes/{routeId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isDriver() && resource.data.driverId == request.auth.uid) ||
          (isGuardian() && request.auth.uid in get(/databases/$(database)/documents/districts/$(districtId)/students/$(request.auth.uid)).data.guardianIds) ||
          isStudent()
        );
        allow create, update, delete: if isAdmin();
      }
      
      // Buses subcollection
      match /buses/{busId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isDriver() && resource.data.driverId == request.auth.uid) ||
          isGuardian() ||
          isStudent()
        );
        allow create, update, delete: if isAdmin();
        allow update: if isDriver() && request.resource.data.keys().hasOnly(['currentLocation', 'lastLocationUpdate']);
      }
      
      // ScanLogs subcollection
      match /scanLogs/{logId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isDriver() && resource.data.driverId == request.auth.uid) ||
          (isGuardian() && request.auth.uid in get(/databases/$(database)/documents/districts/$(districtId)/students/$(resource.data.studentId)).data.guardianIds) ||
          (isStudent() && resource.data.studentId == request.auth.uid)
        );
        allow create: if isDriver();
        allow update: if isDriver() && request.resource.data.keys().hasOnly(['action', 'synced']);
        allow delete: if isAdmin();
      }
      
      // Guardians subcollection
      match /guardians/{guardianId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == guardianId ||
          isAdmin()
        );
        allow create: if isAdmin();
        allow update: if isAuthenticated() && (
          request.auth.uid == guardianId ||
          isAdmin()
        );
        allow delete: if isAdmin();
      }
      
      // GuardianInvites subcollection
      match /guardianInvites/{inviteId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          resource.data.guardianEmail == request.auth.token.email
        );
        allow create: if isAdmin();
        allow update: if isAuthenticated() && (
          isAdmin() ||
          resource.data.guardianEmail == request.auth.token.email
        );
        allow delete: if isAdmin();
      }
    }
  }
}
